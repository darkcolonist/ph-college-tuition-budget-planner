# Local secrets for Edubank PH Worker
# Copy this file to .dev.vars and fill in the actual values.

# REQUIRED: Google Gemini API Key (1.5 Flash recommended)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: Environment name (e.g., development, production)
ENVIRONMENT=development

# OPTIONAL: Port for local worker dev server
PORT=8787
